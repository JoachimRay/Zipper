<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="12.0"
      xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="zipper.UIController">

   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
   </padding>

   <children>

      <Pane fx:id="DropFile" prefWidth="500.0" prefHeight="80.0"
            styleClass="drop-zone"/>

      <VBox fx:id="terminalBox" prefWidth="500.0" spacing="0.0"
            styleClass="term-root">

         <VBox styleClass="term-bar">
            <Label fx:id="termTitle" text="zipper -- compression monitor" styleClass="term-title"/>
         </VBox>

         <VBox fx:id="terminalBody" styleClass="term-body" spacing="0.0">
            <Label fx:id="termCommand"          text="waiting for file..."  styleClass="term-dim"/>
            <Label                              text=""/>
            <Label fx:id="termProgress"         text="Compressing  : 0%"     styleClass="term-white"/>
            <Label fx:id="termChunks"           text="Chunks       : 0 / 0"  styleClass="term-dim"/>
            <Label fx:id="termElapsed"          text="Elapsed      : 0.0s"   styleClass="term-dim"/>
            <Label fx:id="termSpeed"            text="Speed        : 0 MB/s" styleClass="term-dim"/>
            <Label                              text=""/>
            <Label                              text="Threads"                styleClass="term-dim"/>
            <Label                              text=""/>
            <Label fx:id="termCompressedThread"   text="CompressionThread  : (Idle)" styleClass="term-dim"/>
            <Label fx:id="termDecompressThread" text="DecompressionThread: (Idle)" styleClass="term-dim"/>
            <Label                              text=""/>
            <Label                              text="--------------------"   styleClass="term-dim"/>
            <Label                              text=""/>
            <Label fx:id="termStatus"           text="Status       : WAITING" styleClass="term-dim"/>
            <Label                              text=""/>
            <Label fx:id="termOrigBar"          text="Original  : 0 KB"      styleClass="term-dim"/>
            <Label fx:id="termCompBar"          text="Compressed: 0 KB"      styleClass="term-dim"/>
            <Label                              text=""/>
            <Label fx:id="termSaved"            text="Saved      : 0%"       styleClass="term-dim"/>
            <Label fx:id="termRatio"            text="Ratio      : 0.00"     styleClass="term-dim"/>
            <Label fx:id="termTime"             text="Time       : 0.0s"     styleClass="term-dim"/>
         </VBox>

      </VBox>

   </children>
</VBox>